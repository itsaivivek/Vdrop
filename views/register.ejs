<!doctype html>
<html class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Tailwind -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <!-- Flowbite -->
  <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />
</head>

<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen transition-colors duration-300">

  <!-- Container -->
  <div class="w-full max-w-md p-8 bg-white dark:bg-gray-800 rounded-2xl shadow-lg">

    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">Sign Up</h2>

    </div>

    <form action="/user/register" method="post" class="space-y-5">

      <!-- Username -->
      <div>
        <label for="username" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-300">
          Username
        </label>
        <input type="text"
        id="username"
          placeholder="John"
          class="w-full px-4 py-2.5 text-sm border rounded-lg bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-white border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
          name="username"
          required>
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-300">
          Email Address
        </label>
        <input id="email" type="email"
          placeholder="john@example.com"
          class="w-full px-4 py-2.5 text-sm border rounded-lg bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-white border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
          required
          name="email">
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-300">
          Password
        </label>
        <input id="password" type="password"
          placeholder="••••••••"
          class="w-full px-4 py-2.5 text-sm border rounded-lg bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-white border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
          required
          name="password">
      </div>

      <!-- Submit -->
      <button
        class="w-full py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition">
        Create Account
      </button>

    </form>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>

</body>
</html>